{
  "model": "TFIDF + LogisticRegression(multinomial)",
  "emotions_order": [
    "joy",
    "anger",
    "fear",
    "sadness",
    "surprise",
    "disgust",
    "excitement",
    "neutral"
  ],
  "dataset": {
    "source": "huggingface",
    "name": "tanaos/synthetic-emotion-detection-dataset-v1",
    "split": "train",
    "text_key": "text",
    "label_key": "labels",
    "n": 11384
  },
  "train_test_split": {
    "test_size": 0.2,
    "random_state": 42,
    "stratify": true
  },
  "tfidf": {
    "ngram_range": [
      1,
      2
    ],
    "max_features": 50000,
    "min_df": 2
  },
  "logreg": {
    "solver": "lbfgs",
    "multi_class": "multinomial",
    "max_iter": 2000
  },
  "eval": {
    "accuracy": 0.8427755819060166
  },
  "posts_path": "C:\\Users\\tinti\\Desktop\\IRTM_music\\data\\processed\\posts\\posts_clean_expanded.jsonl",
  "output_vector_path": "outputs/emotion_vectors/EmotionVec_posts_model.npy",
  "output_shape": [
    10000,
    8
  ]
}